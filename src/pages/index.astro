---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

const lectures = await getCollection('lectures');
const sorted = lectures.sort((a, b) => a.data.lecture - b.data.lecture);
---

<BaseLayout currentPath="/">
  <div class="content-container">
    <div class="index-header">
      <h1 class="index-title">{siteConfig.title}</h1>
      <p class="index-subtitle">{siteConfig.subtitle}</p>
    </div>

    <div class="lecture-list">
      {sorted.map((lecture) => (
        <a href={`/lectures/${lecture.id}`} class="lecture-item">
          <span class="lecture-item-week">Week {lecture.data.lecture}</span>
          <span class="lecture-item-title">{lecture.data.title}</span>
          <span class="lecture-item-date">{lecture.data.date}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
