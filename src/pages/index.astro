---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const lectures = await getCollection('lectures');
const sorted = lectures.sort((a, b) => a.data.lecture - b.data.lecture);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>모두의 연구소 PyTorch + NPU랩</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="nav-home">PyTorch + NPU랩</a>
        <button class="theme-toggle" type="button" aria-label="Toggle dark mode">
          <span class="icon-sun">&#9788;</span>
          <span class="icon-moon">&#9790;</span>
        </button>
      </nav>
    </header>

    <div class="index-container">
      <h1 class="index-title">모두의 연구소 PyTorch + NPU랩</h1>
      <p class="index-subtitle">PyTorch Internal Lecture Series</p>

      <div class="lecture-list">
        {sorted.map((lecture) => (
          <a href={`/lectures/${lecture.id}`} class="lecture-card">
            <div class="lecture-card-meta">
              <span class="lecture-card-week">Week {lecture.data.lecture}</span>
              <span>{lecture.data.date}</span>
            </div>
            <div class="lecture-card-title">{lecture.data.title}</div>
          </a>
        ))}
      </div>
    </div>

    <script src="../scripts/theme-toggle.js"></script>
  </body>
</html>
