---
interface Props {
  title: string;
  lecture: number;
  date?: string;
}

const { title, lecture, date } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | PyTorch + NPU랩</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css"
    />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="nav-home">PyTorch + NPU랩</a>
      </nav>
    </header>

    <main class="article-container">
      <article class="prose">
        <div class="article-header">
          <span class="article-meta">Week {lecture}{date ? ` · ${date}` : ''}</span>
          <h1 class="article-title">{title}</h1>
        </div>

        <div class="article-body">
          <slot />
        </div>
      </article>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <a href="/">← 목록으로 돌아가기</a>
      </div>
    </footer>
  </body>
</html>
