---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  lecture: number;
  date?: string;
  prevLecture?: { title: string; url: string } | null;
  nextLecture?: { title: string; url: string } | null;
  headings?: Heading[];
}

const { title, lecture, date, prevLecture, nextLecture, headings = [] } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length > 0;
---

<BaseLayout title={title} currentPath="/">
  <div class:list={[hasToc && 'lecture-grid']}>
    {hasToc && <TableOfContents headings={headings} />}
    <div class="content-container">
      <article>
        <div class="article-header">
          <span class="article-meta">Week {lecture}{date ? ` · ${date}` : ''}</span>
          <h1 class="article-title">{title}</h1>
        </div>

        <div class="article-body">
          <slot />
        </div>

        {(prevLecture || nextLecture) && (
          <nav class="prev-next-nav" aria-label="Lecture navigation">
            {prevLecture ? (
              <a href={prevLecture.url} class="prev-next-link prev">
                <span class="prev-next-label">&larr; Previous</span>
                <span class="prev-next-title">{prevLecture.title}</span>
              </a>
            ) : (
              <div />
            )}
            {nextLecture ? (
              <a href={nextLecture.url} class="prev-next-link next">
                <span class="prev-next-label">Next &rarr;</span>
                <span class="prev-next-title">{nextLecture.title}</span>
              </a>
            ) : (
              <div />
            )}
          </nav>
        )}
      </article>
    </div>
  </div>
</BaseLayout>
