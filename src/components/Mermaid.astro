---
/**
 * Pre-rendered Mermaid diagram component.
 *
 * At build time, reads the slot content (mermaid source), hashes it,
 * and inlines the matching pre-rendered light/dark SVGs.
 * No client-side JavaScript required.
 *
 * Run `bun run mermaid:build` to regenerate SVGs after editing diagrams.
 */

import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';
import { join, resolve } from 'node:path';

interface Props {
  scale?: number;
  wide?: boolean;
}

const { scale = 1.0, wide = false } = Astro.props;

// Get the raw mermaid source from the slot
const slotHtml = await Astro.slots.render('default');
// Strip HTML tags and decode HTML entities that Astro double-escapes.
// Order matters: decode &amp; last so &amp;gt; → &gt; → >
const rawText = slotHtml
  .replace(/<[^>]*>/g, '')
  .replace(/&amp;/g, '&')
  .replace(/&gt;/g, '>')
  .replace(/&lt;/g, '<')
  .replace(/&quot;/g, '"')
  .replace(/&#39;/g, "'")
  .trim();

// Hash with the same algorithm as build-mermaid.ts
function normalize(text: string): string {
  return text
    .trim()
    .replace(/\r\n/g, '\n')
    .split('\n')
    .map((line: string) => line.trim())
    .join('\n');
}
const contentHash = createHash('sha256').update(normalize(rawText)).digest('hex').slice(0, 12);

// Read manifest and look up SVGs
const outDir = resolve('src/generated/mermaid');
const manifest = JSON.parse(readFileSync(join(outDir, 'manifest.json'), 'utf-8'));
const entry = manifest[contentHash];

let lightSvg = '';
let darkSvg = '';

if (entry) {
  lightSvg = readFileSync(join(outDir, entry.light), 'utf-8');
  darkSvg = readFileSync(join(outDir, entry.dark), 'utf-8');
} else {
  console.warn(`[Mermaid] No pre-rendered SVG found for hash ${contentHash}. Run: bun run mermaid:build`);
}
---

{entry ? (
  <div
    class:list={['mermaid-wrapper', { 'mermaid-wide': wide }]}
    style={scale !== 1.0 ? `transform: scale(${scale}); transform-origin: top center;` : undefined}
  >
    <div class="mermaid-svg mermaid-light" set:html={lightSvg} />
    <div class="mermaid-svg mermaid-dark" set:html={darkSvg} />
  </div>
) : (
  <div class="mermaid-wrapper">
    <pre class="mermaid-fallback">{rawText}</pre>
  </div>
)}
