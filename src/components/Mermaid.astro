---
interface Props {
  scale?: number;
  wide?: boolean;
}

const { scale = 1.0, wide = false } = Astro.props;
---

<div
  class:list={["mermaid-wrapper", { "mermaid-wide": wide }]}
  style={scale !== 1.0 ? `transform: scale(${scale}); transform-origin: top center;` : undefined}
>
  <pre class="mermaid"><slot /></pre>
</div>

<script>
  import mermaid from 'mermaid';

  // Store original mermaid source for re-rendering on theme change
  const mermaidSources = new Map<Element, string>();
  document.querySelectorAll('pre.mermaid').forEach((pre) => {
    mermaidSources.set(pre, pre.textContent || '');
  });

  function currentTheme(): 'dark' | 'default' {
    return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'default';
  }

  function initMermaid() {
    mermaid.initialize({
      startOnLoad: false,
      theme: currentTheme(),
      securityLevel: 'loose',
    });
  }

  // Post-process SVGs: remove inline constraints and stretch to container
  function postProcessSvgs() {
    document.querySelectorAll('.mermaid-wrapper svg').forEach((svg) => {
      const svgEl = svg as SVGSVGElement;
      if (!svgEl.getAttribute('viewBox')) {
        const w = svgEl.getAttribute('width');
        const h = svgEl.getAttribute('height');
        if (w && h) {
          svgEl.setAttribute('viewBox', `0 0 ${parseFloat(w)} ${parseFloat(h)}`);
        }
      }
      svgEl.removeAttribute('width');
      svgEl.removeAttribute('height');
      svgEl.style.removeProperty('max-width');
      svgEl.style.width = '100%';
    });
  }

  async function renderMermaid() {
    initMermaid();
    await mermaid.run({ querySelector: '.mermaid' });
    postProcessSvgs();
  }

  async function reRenderMermaid() {
    // Restore original source text so mermaid can re-render
    mermaidSources.forEach((source, pre) => {
      // Mermaid replaces <pre> content with SVG; restore original text
      pre.removeAttribute('data-processed');
      pre.innerHTML = source;
    });
    initMermaid();
    await mermaid.run({ querySelector: '.mermaid' });
    postProcessSvgs();
  }

  // Render when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderMermaid);
  } else {
    await renderMermaid();
  }

  // Watch for theme changes and re-render
  const observer = new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      if (mutation.attributeName === 'data-theme') {
        reRenderMermaid();
        break;
      }
    }
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>
