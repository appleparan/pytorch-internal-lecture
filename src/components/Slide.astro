---
interface Props {
  layout?: 'default' | 'cover' | 'center';
  class?: string;
}

const { layout = 'default', class: className = '' } = Astro.props;
---

<section
  class:list={[
    'slide',
    `slide--${layout}`,
    className,
  ]}
  data-slide
>
  <div class="slide-content">
    <slot />
  </div>
</section>
